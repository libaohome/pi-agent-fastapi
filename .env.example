# 服务
CORS_ORIGINS=http://localhost:3000
API_PREFIX=/api/v1

# Swagger UI / OpenAPI 文档（生产可设 DOCS_ENABLED=false 关闭）
DOCS_ENABLED=true
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json

# Supabase（与 pi-agent 共用，可直接复制 ../pi-agent/.env 中对应项）
NEXT_PUBLIC_SUPABASE_URL=https://gvwcxnsogjsaqxqkpanp.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Whisper
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Edge TTS（微软在线语音合成，无需 API Key）
EDGE_TTS_DEFAULT_VOICE=zh-CN-XiaoxiaoNeural

# LangExtract（结构化信息抽取，默认走 OpenAI 兼容网关，可与 pi-agent 共用）
LANGEXTRACT_DEFAULT_PROVIDER=openai
LANGEXTRACT_DEFAULT_MODEL=Qwen/Qwen3-235B-A22B
OPENAI_BASE_URL=https://api-inference.modelscope.cn/v1
OPENAI_API_KEY=ms-...
# Gemini 模式（provider=gemini 时使用）
# LANGEXTRACT_API_KEY=your_gemini_api_key
# Ollama 本地模式
# LANGEXTRACT_OLLAMA_URL=http://localhost:11434

# Playwright 后台沙箱（无头 Chromium，每任务独立 BrowserContext）
# 低内存服务器请保持 false；本地开发需要 /playwright 时再设为 true
PLAYWRIGHT_ENABLED=false
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_CHROMIUM_SANDBOX=true
PLAYWRIGHT_MAX_CONCURRENT=3
PLAYWRIGHT_BLOCK_PRIVATE_NETWORK=true
# PLAYWRIGHT_ALLOWED_HOSTS=example.com,docs.example.com
PLAYWRIGHT_SANDBOX_DIR=.data/playwright-sandbox

# yt-dlp / ffmpeg（ffmpeg 为系统依赖：brew install ffmpeg / apt install ffmpeg）
YTDLP_DOWNLOAD_DIR=.data/ytdlp-downloads
YTDLP_ALLOW_PLAYLIST=false
# YTDLP_PROXY=
# YTDLP_COOKIES_FILE=/path/to/cookies.txt
# FFMPEG_PATH=/usr/local/bin/ffmpeg
# FFPROBE_PATH=/usr/local/bin/ffprobe

# Top5 扩展（trafilatura / unstructured / sentence-transformers / whisperx / presidio）
# 安装: pip install -e ".[dev,ml,top5]"
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
WHISPERX_MODEL=base
WHISPERX_DEVICE=cpu
WHISPERX_COMPUTE_TYPE=int8
WHISPERX_ALIGN=true
# WHISPERX_HF_TOKEN=   # 说话人分离需 HuggingFace Token
PRESIDIO_LANGUAGE=zh

# PaddleOCR
PADDLEOCR_LANG=ch
PADDLEOCR_USE_ANGLE_CLS=true

# 视频/音频处理
VIDEO_WORK_DIR=.data/video-work
AUDIO_WORK_DIR=.data/audio-work
DEMUCS_TIMEOUT_SEC=1800

# 知识图谱
KNOWLEDGE_GRAPH_DIR=.data/knowledge-graphs

# 飞书
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# 企业微信
# WECOM_CORP_ID=
# WECOM_AGENT_ID=
# WECOM_SECRET=

# Coze Studio
# COZE_API_BASE=https://api.coze.cn
# COZE_API_TOKEN=

# n8n
# N8N_WEBHOOK_BASE=https://your-n8n.example.com/webhook
# N8N_API_KEY=

# 图片/视频生成（OpenAI 兼容，可与 pi-agent 共用 OPENAI_*）
# MEDIA_OPENAI_BASE_URL=https://api-inference.modelscope.cn/v1
# MEDIA_OPENAI_API_KEY=ms-...
# DEFAULT_IMAGE_MODEL=dall-e-3
# DEFAULT_VIDEO_MODEL=kling-v1

# Gemini 网页端 AI 生图（gemini-webapi，浏览器 Cookie）
# GEMINI_SECURE_1PSID=          # 必填，浏览器 Cookie __Secure-1PSID
# GEMINI_SECURE_1PSIDTS=        # 可选，部分账号已无此 Cookie，可留空
# GEMINI_PROXY=   # 可选；不设置或留空则不走代理
# GEMINI_TIMEOUT_SEC=600
# GEMINI_IMAGE_DIR=.data/gemini-images
